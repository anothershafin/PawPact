# Copy to .env and adjust. Default API port is 5000.

PORT=5000

# Optional: full origin for uploaded image URLs (defaults to http://localhost:<PORT>)
# PUBLIC_ORIGIN=http://localhost:5000

# MONGO_URI=mongodb://127.0.0.1:27017/pawpact
MONGO_URI=mongodb+srv://PawPact:PawPact1234@pawpact.hrdg5gp.mongodb.net/pawpactDB?retryWrites=true&w=majority
JWT_SECRET=change_me

# Optional: create default admin — run: npm run seed:admin
# SEED_ADMIN_EMAIL=admin@pawpact.local
# SEED_ADMIN_PASSWORD=your_secure_password_here
# SEED_ADMIN_NAME=Administrator
# SEED_ADMIN_PHONE=0000000000
# SEED_ADMIN_DISTRICT=N/A
# SEED_ADMIN_UPAZILLA=N/A
# If that email already exists as adopter/petparent: SEED_UPGRADE_NON_ADMIN=1
